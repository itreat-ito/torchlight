{
  "manifest_version": 3,
  "name": "Environment Banner",
  "version": "1.0.0",
  "description": "Display a banner to visually distinguish between local, staging, and production environments",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "src/options/options.html",
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
